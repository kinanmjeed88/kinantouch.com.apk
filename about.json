{
  "profileName": "\u0643\u0646\u0627\u0646 \u0627\u0644\u0635\u0627\u0626\u063a",
  "profileImage": "assets/images/1774458438604_Screenshot_\u0662\u0660\u0662\u0665-\u0660\u0663-\u0662\u0668-\u0662\u0660-\u0665\u0664-\u0662\u0665-\u0669\u0663_99c04817c0de5652397fc8b56c3b3817.webp",
  "bio": "\u0623\u0646\u0627 \u0643\u0646\u0627\u0646 \u0645\u062c\u064a\u062f \u0627\u0644\u0635\u0627\u0626\u063a\u060c \u0645\u0646 \u0645\u0648\u0627\u0644\u064a\u062f 1988\u060c \u0645\u0647\u062a\u0645 \u0628\u0627\u0644\u0623\u062e\u0628\u0627\u0631 \u0648\u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u062a\u0642\u0646\u064a\u0629 \u0648\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a. \u0623\u0639\u0645\u0644 \u0639\u0644\u0649 \u0646\u0634\u0631 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u062a\u0642\u0646\u064a\u060c \u0648\u0623\u062f\u0648\u0627\u062a \u0648\u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0645\u0639\u062f\u0644\u0629.",
  "botInfo": "\u0646\u062d\u0646 \u0641\u064a Kinantouch \u0646\u062d\u062a\u0631\u0645 \u062e\u0635\u0648\u0635\u064a\u0629 \u0632\u0648\u0627\u0631\u0646\u0627 \u0648\u0646\u0644\u062a\u0632\u0645 \u0628\u062d\u0645\u0627\u064a\u0629 \u0623\u064a \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u064a\u062a\u0645 \u062c\u0645\u0639\u0647\u0627 \u0623\u062b\u0646\u0627\u0621 \u062a\u0635\u0641\u062d \u0627\u0644\u0645\u0648\u0642\u0639.\n\u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0643 \u0644\u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u0641\u0625\u0646\u0643 \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u0645\u0648\u0636\u062d\u0629 \u0623\u062f\u0646\u0627\u0647.\n\n\u0642\u062f \u064a\u062a\u0645 \u0639\u0631\u0636 \u0625\u0639\u0644\u0627\u0646\u0627\u062a \u0645\u0646 \u0637\u0631\u0641 \u062b\u0627\u0644\u062b \u0639\u0628\u0631 \u0634\u0628\u0643\u0629 Adsterra..\n\u0627\u0644\u0645\u0648\u0642\u0639 \u0644\u0627 \u064a\u062a\u062d\u0643\u0645 \u0628\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0625\u0639\u0644\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0639\u0631\u0648\u0636\u0629.",
